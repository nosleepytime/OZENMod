# ── Twitch application ────────────────────────────────────────────────────────
# Create an app at https://dev.twitch.tv/console/apps
# OAuth redirect URL: <NEXT_PUBLIC_APP_URL>/api/auth/callback
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ── Web app ───────────────────────────────────────────────────────────────────
# Public base URL, no trailing slash (Vercel sets its own in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Firebase (server) ─────────────────────────────────────────────────────────
# Service account JSON for the Admin SDK — mints the sign-in custom token.
# Paste the whole JSON on a single line (Project settings -> Service accounts ->
# Generate new private key). Keep this secret; it never reaches the browser.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Firebase (public client config) ───────────────────────────────────────────
# From Project settings -> General -> "Your apps" -> SDK setup and configuration.
# These are safe to expose: access is controlled by database.rules.json, not by
# keeping them secret.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional — defaults to <projectId>.firebaseapp.com when omitted.
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=

# ── AI web search (Keenable) — FREE, no key needed ────────────────────────────
# The AI Assistant searches the web via Keenable (verify links/scams, look up
# people, games, events, current news). This works with NO API key on the free
# tier (1000 requests/hour). Leave both blank and it just works.
# Optional: set a free key (https://keenable.ai) ONLY to raise the rate limits.
# The key is server-side and never sent to the browser or shipped in the app.
KEENABLE_API_KEY=
OZENMOD_KEENABLE_API_KEY=

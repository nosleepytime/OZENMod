# ── Twitch application ────────────────────────────────────────────────────────
# Create an app at https://dev.twitch.tv/console/apps
# OAuth redirect URL: <NEXT_PUBLIC_APP_URL>/api/auth/callback
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ── Web app ───────────────────────────────────────────────────────────────────
# Public base URL, no trailing slash (Vercel sets its own in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Firebase (wired in milestone M4 — leave empty until then) ─────────────────
# Service account JSON for the Admin SDK (auth custom tokens), single line
FIREBASE_SERVICE_ACCOUNT_JSON=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
